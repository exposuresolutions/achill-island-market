# Moonshot Kimi API (required for live AI replies)
KIMI_API_KEY=your_moonshot_api_key_here

# Optional — default matches Moonshot OpenAI-compatible endpoint
KIMI_BASE_URL=https://api.moonshot.ai/v1/chat/completions

# Optional — model id
KIMI_MODEL=kimi-k2.5

# Render sets PORT automatically; optional for local dev
# PORT=3001
