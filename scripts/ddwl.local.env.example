# Copy to scripts/ddwl.local.env and fill in (never commit the copy).
# Load in PowerShell: Get-Content .\scripts\ddwl.local.env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim(), 'Process') } }

RENDER_API_KEY=
# Or set service id directly (skips name lookup):
# RENDER_SERVICE_ID=srv-xxxxxxxx

KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.ai/v1
GROQ_API_KEY=

TG_BOT_TOKEN=
TG_CHAT_ID=
TG_ALLOWED_USERS=
NOTIFY_ENABLED=true
TG_BOT_LABEL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_LABEL=
